{
  "name": "obsidian-ai-spend-tracker",
  "version": "1.0.0",
  "description": "Track GitHub Copilot and Claude.ai spend in Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "copilot",
    "claude",
    "spend",
    "budget"
  ],
  "author": "Ken Tse",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.17.19",
    "obsidian": "1.13.1",
    "tslib": "2.6.0",
    "typescript": "5.9.3"
  }
}
